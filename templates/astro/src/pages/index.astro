---
const projects = [
  {
    title: "Project one",
    description: "Describe the work, your role, and the result.",
  },
  {
    title: "Project two",
    description: "Use Astro when you want components without a heavy client bundle.",
  },
  {
    title: "Project three",
    description: "This starter is static by default, which keeps GitHub Pages simple.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Your Name | Astro Website</title>
    <style>
      :root {
        --bg: #f4efe7;
        --paper: rgba(255, 252, 246, 0.88);
        --ink: #1c1917;
        --muted: #5f564b;
        --line: rgba(28, 25, 23, 0.12);
        --accent: #c4683b;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Georgia, serif;
        color: var(--ink);
        background:
          radial-gradient(circle at top left, rgba(196, 104, 59, 0.16), transparent 28%),
          linear-gradient(180deg, #f6f0e7 0%, #efe7dc 100%);
      }

      main {
        width: min(calc(100% - 32px), 1100px);
        margin: 24px auto 48px;
      }

      section {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 28px;
        padding: 28px;
        margin-bottom: 24px;
      }

      h1 {
        font-size: clamp(3rem, 8vw, 6rem);
        line-height: 0.95;
        max-width: 10ch;
        margin: 12px 0;
      }

      h2 {
        font-size: clamp(2rem, 4vw, 3rem);
      }

      p,
      li {
        font-family: Arial, sans-serif;
        line-height: 1.7;
        color: var(--muted);
      }

      .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--accent);
        font-size: 0.78rem;
      }

      .cards {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
        padding: 0;
        list-style: none;
      }

      .card {
        border: 1px solid var(--line);
        border-radius: 20px;
        padding: 20px;
        background: rgba(255, 255, 255, 0.55);
      }

      @media (max-width: 800px) {
        .cards {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <section>
        <p class="eyebrow">Astro + GitHub Pages</p>
        <h1>Choose Astro when you want structure without full app overhead.</h1>
        <p>
          This starter is static by default. Use Astro components and content
          organization, then deploy through the GitHub Pages workflow.
        </p>
      </section>

      <section>
        <p class="eyebrow">Projects</p>
        <h2>Show the work clearly.</h2>
        <ul class="cards">
          {
            projects.map((project) => (
              <li class="card">
                <h3>{project.title}</h3>
                <p>{project.description}</p>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
  </body>
</html>
